# LLM: "openai" (normal cloud), "bytez" (Bytez/custom), or "local" (Ollama)
# Use "openai" + OPENAI_API_KEY for a normal LLM – no Ollama needed.
LLM_PROVIDER=openai

# OpenAI (normal cloud LLM) – same key can be used for embeddings if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_LLM_MODEL=gpt-4o-mini

# Optional: Local LLM (Ollama) – only if LLM_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: Bytez – use OpenAI-compatible endpoint; model must be prefixed (e.g. openai/gpt-4o-mini)
BYTEZ_API_KEY=
BYTEZ_BASE_URL=https://api.bytez.com/models/v2/openai/v1
BYTEZ_MODEL=openai/gpt-4o-mini

# Embeddings: "openai" with text-embedding-3-large (3072 dimensions)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Pinecone – assessment2026 index (dimension must match index; e.g. 1024)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=assessment2026
PINECONE_INDEX_DIMENSION=1024
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# CORS (comma-separated; on Render set to your Vercel URL)
CORS_ORIGINS=http://localhost:3000
